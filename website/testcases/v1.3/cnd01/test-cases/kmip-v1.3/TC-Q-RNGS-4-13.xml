      </RNGParameters>
      <RNGParameters>
        <RNGAlgorithm type="Enumeration" value="DRBG"/>
        <CryptographicAlgorithm type="Enumeration" value="HMAC_SHA1"/>
        <DRBGAlgorithm type="Enumeration" value="HMAC"/>
