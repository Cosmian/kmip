# [[Query]]
#
# Perform a Query operation, querying the Operations and Objects supported
# by the server, and get a successful response.
#
# The specific list of operations and object types returned in the response
# MAY vary.

<RequestMessage>
  <RequestHeader>
    <ProtocolVersion>
      <ProtocolVersionMajor type="Integer" value="2"/>
      <ProtocolVersionMinor type="Integer" value="0"/>
    </ProtocolVersion>
    <ClientCorrelationValue type="TextString" value="SUITEB_192-M-1-20 step=0"/>
    <BatchCount type="Integer" value="1"/>
  </RequestHeader>
  <BatchItem>
    <Operation type="Enumeration" value="Query"/>
    <RequestPayload>
      <QueryFunction type="Enumeration" value="QueryOperations"/>
      <QueryFunction type="Enumeration" value="QueryObjects"/>
    </RequestPayload>
  </BatchItem>
</RequestMessage>


